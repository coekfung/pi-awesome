{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "lib": ["ES2022"]
  },
  "include": [
    "perf/**/*.ts",
    "nono/**/*.ts",
    "notebook-edit/**/*.ts",
    "mcp/**/*.ts"
  ]
}
